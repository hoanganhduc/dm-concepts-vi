<?xml version="1.0" encoding="utf-8"?>
<!-- Project manifest for "Một số thuật ngữ trong Toán rời rạc". -->
<!-- Build:  pretext build web   |   pretext build print   |   pretext view -->
<project ptx-version="2">
  <targets>
    <target name="web" format="html" />
    <!-- xelatex is required for Vietnamese (Unicode) text in the PDF. -->
    <target name="print" format="pdf" latex-engine="xelatex" />
  </targets>
</project>
