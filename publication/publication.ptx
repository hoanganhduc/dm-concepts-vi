<?xml version="1.0" encoding="UTF-8"?>
<!-- Publication file: controls how the book is built and how it looks. -->
<publication>
  <common>
    <tableofcontents level="2" />
  </common>

  <source>
    <directories external="../assets" generated="../generated-assets" />
  </source>

  <latex>
    <!-- Tighter margins so the lexicon fits more text per page (fewer pages).
         The PreTeXt default text block is ~340pt wide on letter paper (very wide
         margins); 0.9in margins widen it to ~6.7in. -->
    <page>
      <geometry>letterpaper, margin=0.9in</geometry>
    </page>
  </latex>

  <html>
    <!-- Native full-text search of the web output (lookup layer 1, see docs/PLAN.md §5). -->
    <search variant="default" />
    <!-- Focused, expandable table of contents to ease browsing a long A–Z lexicon. -->
    <toc focused="yes" preexpanded-levels="1" />
    <!-- Definitions open in place (as knowls) for quick lookup without losing your place. -->
    <knowl definition="yes" example="yes" />
  </html>
</publication>
