    <subtitle>Từ điển chú giải Anh–Việt — Selected Terms in Discrete Mathematics</subtitle>

    <xi:include href="./frontmatter.ptx" />

    <!-- Chapters A–Z (added incrementally). Pilot: C. -->
    <xi:include href="./ch-c.ptx" />

    <xi:include href="./backmatter.ptx" />
  </book>
</pretext>
